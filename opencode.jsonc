{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "angular-architect",
  "formatter": {
    "prettier": {
      "disabled": true,
    },
    "oxfmt": {
      "command": [
        "pnpm",
        "format"
      ],
      "extensions": [
        ".ts"
      ],
    },
  },
  "mcp": {
    "angular-cli": {
      "enabled": true,
      "command": [
        "pnx",
        "@angular/cli",
        "mcp"
      ],
      "type": "local",
    },
    "ngp-mcp": {
      "command": [
        "pnx",
        "@ng-primitives/mcp"
      ],
      "enabled": true,
      "type": "local",
    },
    "figma": {
      "type": "remote",
      "url": "http://172.20.240.1:3845/mcp",
      "enabled": false,
    },
  },
}
