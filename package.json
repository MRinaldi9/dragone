{
  "name": "dragone",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "vitest",
    "lint:eslint": "eslint",
    "lint:oxlint": "oxlint",
    "lint:all": "pnpm lint:oxlint & pnpm lint:eslint",
    "lint:package": "publint ./projects/dragone/ui",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "commit": "cz",
    "storybook": "ng run @dragone/ui:storybook",
    "build-storybook": "ng run @dragone/ui:build-storybook"
  },
  "dependencies": {
    "@angular/cdk": "^21.2.7",
    "@angular/common": "^21.2.9",
    "@angular/compiler": "^21.2.9",
    "@angular/core": "^21.2.9",
    "@angular/forms": "^21.2.9",
    "@angular/platform-browser": "^21.2.9",
    "@angular/router": "^21.2.9",
    "@floating-ui/dom": "^1.7.6",
    "@ng-icons/core": "^33.2.1",
    "@ng-icons/font-awesome": "^33.2.1",
    "ng-primitives": "^0.117.0",
    "rxjs": "~7.8.2",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@analogjs/storybook-angular": "^2.4.8",
    "@analogjs/vite-plugin-angular": "^2.4.8",
    "@analogjs/vitest-angular": "^2.4.8",
    "@angular-devkit/build-angular": "21.2.7",
    "@angular-eslint/builder": "21.3.1",
    "@angular-eslint/eslint-plugin": "^21.3.1",
    "@angular/build": "^21.2.7",
    "@angular/cli": "^21.2.7",
    "@angular/compiler-cli": "^21.2.9",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@compodoc/compodoc": "1.2.1",
    "@eslint/js": "^10.0.1",
    "@storybook/addon-a11y": "10.3.5",
    "@storybook/addon-docs": "10.3.5",
    "@storybook/addon-onboarding": "10.3.5",
    "@storybook/angular": "^10.3.5",
    "@types/node": "^24.12.0",
    "@vitest/browser": "^4.1.4",
    "@vitest/browser-playwright": "^4.1.4",
    "@vitest/coverage-v8": "4.1.4",
    "angular-eslint": "21.3.1",
    "commitizen": "^4.3.1",
    "cz-conventional-changelog": "^3.3.0",
    "eslint": "^10.2.0",
    "eslint-plugin-storybook": "10.3.5",
    "lefthook": "^2.1.6",
    "ng-packagr": "^21.2.2",
    "oxfmt": "^0.45.0",
    "oxlint": "^1.60.0",
    "playwright": "^1.59.1",
    "publint": "^0.3.18",
    "storybook": "10.3.5",
    "typescript": "~5.9.3",
    "typescript-eslint": "8.58.2",
    "vite": "^8.0.8",
    "vitest": "^4.1.4"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  },
  "engines": {
    "npm": "Please use pnpm instead of NPM to install dependencies",
    "pnpm": ">=10.32.0",
    "yarn": "Please use pnpm instead of Yarn to install dependencies"
  },
  "packageManager": "pnpm@10.32.1"
}
