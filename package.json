{
  "name": "dragone",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "vitest",
    "lint:eslint": "eslint",
    "lint:oxlint": "oxlint",
    "lint:all": "pnpm lint:oxlint & pnpm lint:eslint",
    "lint:package": "publint ./projects/dragone/ui",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "commit": "cz",
    "storybook": "ng run @dragone/ui:storybook",
    "build-storybook": "ng run @dragone/ui:build-storybook"
  },
  "dependencies": {
    "@angular/cdk": "^22.0.0-rc.1",
    "@angular/common": "^22.0.0-rc.1",
    "@angular/compiler": "^22.0.0-rc.1",
    "@angular/core": "^22.0.0-rc.1",
    "@angular/forms": "^22.0.0-rc.1",
    "@angular/platform-browser": "^22.0.0-rc.1",
    "@angular/router": "^22.0.0-rc.1",
    "@floating-ui/dom": "^1.7.6",
    "@ng-icons/core": "^33.2.2",
    "@ng-icons/font-awesome": "^33.2.2",
    "@ng-primitives/mcp": "^0.120.4",
    "ng-primitives": "^0.120.4",
    "rxjs": "~7.8.2",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@analogjs/storybook-angular": "^2.5.2",
    "@analogjs/vite-plugin-angular": "^2.5.2",
    "@analogjs/vitest-angular": "^2.5.2",
    "@angular-eslint/builder": "21.4.0",
    "@angular-eslint/eslint-plugin": "^21.4.0",
    "@angular/build": "^22.0.0-rc.1",
    "@angular/cli": "^22.0.0-rc.1",
    "@angular/compiler-cli": "^22.0.0-rc.1",
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "@compodoc/compodoc": "1.2.1",
    "@eslint/js": "^10.0.1",
    "@storybook/addon-a11y": "10.4.1",
    "@storybook/addon-docs": "10.4.1",
    "@storybook/addon-onboarding": "10.4.1",
    "@storybook/angular": "10.4.1",
    "@types/node": "^24.12.0",
    "@vitest/browser": "^4.1.7",
    "@vitest/browser-playwright": "^4.1.7",
    "@vitest/coverage-v8": "4.1.7",
    "angular-eslint": "21.4.0",
    "commitizen": "^4.3.1",
    "cz-conventional-changelog": "^3.3.0",
    "eslint": "^10.4.0",
    "eslint-plugin-storybook": "10.4.1",
    "lefthook": "^2.1.8",
    "ng-packagr": "^22.0.0-next.4",
    "oxfmt": "^0.51.0",
    "oxlint": "^1.66.0",
    "playwright": "^1.60.0",
    "publint": "^0.3.21",
    "storybook": "10.4.1",
    "typescript": "~6.0.3",
    "typescript-eslint": "8.59.4",
    "vite": "^8.0.14",
    "vitest": "^4.1.7"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  },
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "onFail": "error",
      "version": ">=11.0.0"
    },
    "runtime": {
      "name": "node",
      "onFail": "error"
    }
  }
}
